---
import styles from "./ModalBase.module.css";

interface Props {
    id: string;
    modalName: string;
}

const { id, modalName } = Astro.props;
---

<dialog id={id} class={styles.dialog} data-modal-name={modalName}>
    <div class={styles.modalContent}>
        <button
            type="button"
            class={styles.closeButton}
            data-close-modal
            aria-label="Close modal"
        >
            <svg
                width="12"
                height="12"
                viewBox="0 0 12 12"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    d="M10.5 1.5L1.5 10.5M1.5 1.5L10.5 10.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"></path>
            </svg>
        </button>
        <div class={styles.modalWrapper}>
            <slot />
        </div>
    </div>
</dialog>

<script>
    import { $modals, closeModalAction } from "@/store/modalStore";

    // Standard behavior for all ModalBase instances
    function setupModalBase(dialog) {
        const modalName = dialog.dataset.modalName;
        const closeBtn = dialog.querySelector("[data-close-modal]");

        const handleClose = () => {
            if (modalName) {
                closeModalAction(modalName);
            }
        };

        closeBtn?.addEventListener("click", handleClose);

        // Close on backdrop click (native behavior for dialog usually requires JS for backdrop specifically)
        dialog.addEventListener("click", (e) => {
            if (e.target === dialog) {
                handleClose();
            }
        });

        // Sync with store
        $modals.subscribe((modals) => {
            const isOpen = modals.some((m) => m.name === modalName);
            if (isOpen) {
                if (!dialog.open) dialog.showModal();
            } else {
                if (dialog.open) dialog.close();
            }
        });
    }

    // Initialize all existing dialogs that use this structure
    document.querySelectorAll("dialog[data-modal-name]").forEach((el) => {
        setupModalBase(el);
    });

    // Handle dynamically added modals (if any via templates)
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
                if (node instanceof HTMLElement) {
                    const dialogs =
                        node.nodeName === "DIALOG"
                            ? [node]
                            : node.querySelectorAll("dialog[data-modal-name]");
                    dialogs.forEach((d) => {
                        if (!d.dataset.initialized) {
                            d.dataset.initialized = "true";
                            setupModalBase(d);
                        }
                    });
                }
            });
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
</script>
