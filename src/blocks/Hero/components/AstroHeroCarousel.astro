---
import styles from "./AstroHeroCarousel.module.css";
import VideoSlide from "./VideoSlide.astro";

interface Props {
    slides: any[];
    autoPlay?: boolean;
    interval?: number;
}

const { slides = [], autoPlay = true, interval = 5000 } = Astro.props;

if (!slides || slides.length === 0) return null;
---

<div
    class={styles.carousel}
    id="hero-carousel"
    data-autoplay={autoPlay}
    data-interval={interval}
>
    <div
        class={styles.slidesContainer}
        id="hero-slides-container"
        style={`transform: translateX(0%)`}
    >
        {
            slides.map((slide, index) => (
                <div class={styles.slide}>
                    <VideoSlide
                        index={index}
                        isActive={index === 0}
                        data={slide.data}
                    />
                </div>
            ))
        }
    </div>

    {
        slides.length > 1 && (
            <>
                <button
                    class={`${styles.navButton} ${styles.prev} hero-carousel-prev`}
                    aria-label="Previous slide"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class={styles.iconPrev}
                    >
                        <path
                            stroke="currentColor"
                            stroke-width="1.5"
                            d="m15 18-6-6 6-6"
                        />
                    </svg>
                </button>
                <button
                    class={`${styles.navButton} ${styles.next} hero-carousel-next`}
                    aria-label="Next slide"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class={styles.iconNext}
                    >
                        <path
                            stroke="currentColor"
                            stroke-width="1.5"
                            d="m9 6 6 6-6 6"
                        />
                    </svg>
                </button>

                <div class={styles.dots}>
                    {slides.map((_, index) => (
                        <button
                            class={`${styles.dot} hero-carousel-dot`}
                            data-index={index}
                            data-active={index === 0 ? "true" : "false"}
                            aria-label={`Go to slide ${index + 1}`}
                        />
                    ))}
                </div>
            </>
        )
    }
</div>

<script>
    function initHeroCarousel() {
        const carousel = document.getElementById("hero-carousel");
        const container = document.getElementById("hero-slides-container");
        if (!carousel || !container) return;

        const slides = container.children;
        const dots = carousel.querySelectorAll(".hero-carousel-dot");
        const prevBtn = carousel.querySelector(".hero-carousel-prev");
        const nextBtn = carousel.querySelector(".hero-carousel-next");

        const autoPlay = carousel.dataset.autoplay === "true";
        const interval = parseInt(carousel.dataset.interval || "5000");

        let currentIndex = 0;
        let timer = null;
        let isHovered = false;

        const resetTimer = () => {
            if (timer) clearInterval(timer);

            const currentSlideEl = slides[currentIndex];
            const hasVideo = currentSlideEl
                ? !!currentSlideEl.querySelector("video")
                : false;

            // React logic: if (autoPlay && !isHovered && slides[currentSlide]?.type !== 'video')
            if (autoPlay && !isHovered && !hasVideo) {
                timer = setInterval(next, interval);
            }
        };

        const updateCarousel = (index) => {
            currentIndex = (index + slides.length) % slides.length;
            container.style.transform = `translateX(-${currentIndex * 100}%)`;

            dots.forEach((dot, i) => {
                dot.setAttribute(
                    "data-active",
                    i === currentIndex ? "true" : "false",
                );
            });

            // Handle video play/pause
            Array.from(slides).forEach((slide, i) => {
                const video = slide.querySelector("video");
                if (video) {
                    if (i === currentIndex) {
                        video.play().catch(() => {});
                    } else {
                        video.pause();
                        video.currentTime = 0;
                    }
                }
            });

            resetTimer();
        };

        const next = () => updateCarousel(currentIndex + 1);
        const prev = () => updateCarousel(currentIndex - 1);

        if (prevBtn) {
            prevBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                prev();
            });
        }
        if (nextBtn) {
            nextBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                next();
            });
        }

        dots.forEach((dot, i) => {
            dot.addEventListener("click", (e) => {
                e.stopPropagation();
                updateCarousel(i);
            });
        });

        // Video End logic (onEnded={onEnd} hook)
        Array.from(slides).forEach((slide) => {
            const video = slide.querySelector("video");
            if (video) {
                video.addEventListener("ended", () => {
                    next();
                });
            }
        });

        // Swipe support (Match React's clientX)
        let touchStartX = 0;
        let touchEndX = 0;

        carousel.addEventListener(
            "touchstart",
            (e) => {
                touchStartX = e.targetTouches[0].clientX;
            },
            { passive: true },
        );

        carousel.addEventListener(
            "touchmove",
            (e) => {
                touchEndX = e.targetTouches[0].clientX;
            },
            { passive: true },
        );

        carousel.addEventListener(
            "touchend",
            () => {
                const diff = touchStartX - touchEndX;
                if (diff > 50) next();
                else if (diff < -50) prev();
            },
            { passive: true },
        );

        // Hover logic for visibility and timer
        carousel.addEventListener("mouseenter", () => {
            isHovered = true;
            if (prevBtn) prevBtn.setAttribute("data-visible", "true");
            if (nextBtn) nextBtn.setAttribute("data-visible", "true");
            resetTimer();
        });
        carousel.addEventListener("mouseleave", () => {
            isHovered = false;
            if (prevBtn) prevBtn.removeAttribute("data-visible");
            if (nextBtn) nextBtn.removeAttribute("data-visible");
            resetTimer();
        });

        updateCarousel(0); // Initial check
    }

    initHeroCarousel();
    document.addEventListener("astro:page-load", initHeroCarousel);
</script>
