---
import ServiceCard from "@/ui/ServiceCard/ServiceCard.astro";
import styles from "./MountingTypes.module.css";
import OptionalAddons from "./components/OptionalAddons.astro";
import Text from "../../ui/Text/Text.astro";
import { getBaseUrl } from "../../lib/env";

const baseUrl = getBaseUrl();

async function getMountingTypes() {
  const res = await fetch(
    `${baseUrl}/api/tv-mounting-type?populate[mountingTypes][populate]=*`,
  );
  const json = await res.json();
  return json.data;
}

const { data = {} } = Astro.props;
const defaultMountingData = await getMountingTypes();

const normalizedBlockData = Array.isArray(defaultMountingData)
  ? defaultMountingData[0]
  : defaultMountingData;
const blockData = normalizedBlockData?.attributes || normalizedBlockData || {};

const rawMountingTypes =
  data?.mountingTypes?.length > 0
    ? data.mountingTypes
    : blockData.mountingTypes?.data || blockData.mountingTypes || [];

const mountingData = {
  ...blockData,
  ...data,
  title: data?.title || blockData.title || "TV Mounting Types",
  subTitle:
    data?.subTitle ||
    blockData.subTitle ||
    "Secure, high-quality mounting options",
  mountingTypes: rawMountingTypes,
  addons:
    data?.addons && data.addons.length > 0
      ? data.addons
      : defaultMountingData.addons,
};
---

<section class={`block ${styles.mountingTypes}`}>
  <header>
    <h2 class="blockHeading">
      <Text text={mountingData.title} />
    </h2>
    <p class="subText">
      <Text text={mountingData.subTitle} />
    </p>
  </header>
  <div class={styles.cardsGrid}>
    {
      mountingData.mountingTypes &&
        mountingData.mountingTypes.length > 0 &&
        mountingData.mountingTypes.map((card, index) => (
          <ServiceCard
            image={card.image}
            title={card.title}
            description={card.description}
            buttonText="Book Now"
            modalName="BookNow"
          />
        ))
    }
  </div>
  <OptionalAddons addons={mountingData.addons || []} />
</section>
