---
import styles from "./CertificateCard.module.css";
import ImageWrapper from "@/ui/ImageWrapper/ImageWrapper.astro";

interface Props {
    image: any;
    className?: string;
    certificates: any[];
    currentIndex: number;
}

const { image, className, certificates, currentIndex } = Astro.props;
---

<div
    class={`${styles.certificateCard} ${className} certificate-trigger`}
    tabindex="0"
    role="button"
    data-index={currentIndex}
>
    {
        image && (
            <ImageWrapper
                media={image}
                className={styles.image}
                defaultAlt="Professional Certification"
                width={350}
                sizes="(max-width: 768px) 212px, 350px"
            />
        )
    }
</div>

<template id="certificate-modal-template">
    <dialog class="certificate-dialog">
        <div class={styles.modalContainer}>
            <div class={styles.imageContainer}>
                <ImageWrapper
                    media={image}
                    defaultAlt="Professional Certification"
                    width={400}
                />
            </div>
            <button class={styles.arrowLeft} id="modal-prev">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none"
                    ><path
                        d="M15 18l-6-6 6-6"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path></svg
                >
            </button>
            <div class={styles.modalMediaContainer} id="modal-media-container">
                <img
                    class={styles.modalImage}
                    id="modal-main-image"
                    src=""
                    alt="Enlarged Certificate View"
                />
            </div>
            <button class={styles.arrowRight} id="modal-next">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none"
                    ><path
                        d="M9 18l6-6-6-6"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path></svg
                >
            </button>
            <button class="modal-close-btn" id="modal-close">×</button>
        </div>
    </dialog>
</template>

<style is:global>
    .certificate-dialog {
        padding: 0;
        border: none;
        background: transparent;
        max-width: 90vw;
        max-height: 90vh;
        outline: none;
    }
    .certificate-dialog::backdrop {
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(4px);
    }
    .modal-close-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.2);
        border: none;
        color: white;
        font-size: 30px;
        cursor: pointer;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
    }
</style>

<script define:vars={{ certificates }}>
    function initCertificateModal() {
        const triggers = document.querySelectorAll(".certificate-trigger");
        let dialog = document.querySelector(".certificate-dialog");

        if (!dialog) {
            const template = document.getElementById(
                "certificate-modal-template",
            );
            if (template) {
                document.body.appendChild(template.content.cloneNode(true));
                dialog = document.querySelector(".certificate-dialog");
            }
        }

        if (!dialog) return;

        const mainImage = dialog.querySelector("#modal-main-image");
        const prevBtn = dialog.querySelector("#modal-prev");
        const nextBtn = dialog.querySelector("#modal-next");
        const closeBtn = dialog.querySelector("#modal-close");
        const mediaContainer = dialog.querySelector("#modal-media-container");

        let currentIndex = 0;

        const updateModal = (index) => {
            currentIndex = (index + certificates.length) % certificates.length;
            const cert = certificates[currentIndex];
            if (cert && mainImage) {
                mainImage.src = cert.url;
            }
        };

        triggers.forEach((trigger) => {
            trigger.addEventListener("click", () => {
                const index = parseInt(trigger.dataset.index || "0");
                updateModal(index);
                dialog.showModal();
            });
        });

        if (prevBtn)
            prevBtn.addEventListener("click", () =>
                updateModal(currentIndex - 1),
            );
        if (nextBtn)
            nextBtn.addEventListener("click", () =>
                updateModal(currentIndex + 1),
            );
        if (closeBtn) closeBtn.addEventListener("click", () => dialog.close());

        dialog.addEventListener("click", (e) => {
            if (e.target === dialog) dialog.close();
        });

        // Swipe support
        let touchStartX = 0;
        mediaContainer?.addEventListener(
            "touchstart",
            (e) => {
                touchStartX = e.changedTouches[0].screenX;
            },
            { passive: true },
        );

        mediaContainer?.addEventListener(
            "touchend",
            (e) => {
                const touchEndX = e.changedTouches[0].screenX;
                const diff = touchStartX - touchEndX;
                if (diff > 50) updateModal(currentIndex + 1);
                else if (diff < -50) updateModal(currentIndex - 1);
            },
            { passive: true },
        );
    }

    initCertificateModal();
    document.addEventListener("astro:page-load", initCertificateModal);
</script>
