---
import styles from "./CustomerReviews.module.css";
import QuoteButton from "../../ui/QuoteButton/QuoteButton.astro";
import Text from "../../ui/Text/Text.astro";
import { getBaseUrl } from "../../lib/env";

const baseUrl = getBaseUrl();

async function getCustomerReviews() {
  const res = await fetch(`${baseUrl}/api/customer-review?populate=*`);
  const json = await res.json();
  return json.data;
}

const { data = {} } = Astro.props;
const defaultReviewsData = await getCustomerReviews();

const normalizedBlockData = Array.isArray(defaultReviewsData)
  ? defaultReviewsData[0]
  : defaultReviewsData;
const blockData = normalizedBlockData?.attributes || normalizedBlockData || {};

const customerReviewsData = {
  ...blockData,
  ...data,
  title: data?.title || blockData.title,
  subTitle: data?.subTitle || blockData.subTitle,
};
---

<script>
  function initReviewsWidget() {
    const target = document.getElementById("reviews-widget-container");
    if (!target) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          const script = document.createElement("script");
          script.src = "https://static.elfsight.com/platform/platform.js";
          script.async = true;
          script.defer = true;
          document.head.appendChild(script);

          const widget = document.createElement("div");
          widget.className =
            "elfsight-app-69970c0c-7b24-44cf-a320-13f567ee7453";
          widget.dataset.elfsightAppLazy = "true";
          target.appendChild(widget);

          observer.disconnect();
        }
      },
      { rootMargin: "200px" },
    );

    observer.observe(target);
  }

  initReviewsWidget();
  document.addEventListener("astro:page-load", initReviewsWidget);
</script>

<style>
  #reviews-widget-container {
    min-height: 400px;
    width: 100%;
    display: flex;
    justify-content: center;
  }
</style>

<section class={`block ${styles.customerReviews}`}>
  <header class={styles.customerReviewsHeader}>
    <h2 class="blockHeading">
      <Text text={customerReviewsData.title} />
    </h2>
    <p class="subText"><Text text={customerReviewsData.subTitle} /></p>
  </header>

  <div class={"widget tt"} id="tt-review-widget-star">
    <img
      src="https://cdn.thumbtackstatic.com/fe-assets-web/media/logos/thumbtack/wordmark.svg"
      alt="Thumbtack"
      class="tt-logo"
      width="86"
      height="21"
    />
    <a
      target="_blank"
      href="https://www.thumbtack.com/tx/houston/tv-wall-mount-install/tvprohandyservices/service/538968360070111254"
    >
      <div>TVProHandyservices</div>
    </a>
    <div id="tt-dynamic">
      <img
        src="https://cdn.thumbtackstatic.com/fe-assets-web/media/pages/profile/standard-widgets/review-widget/orange_star.svg"
        alt="Star"
        width="16"
        height="16"
      />
      <img
        src="https://cdn.thumbtackstatic.com/fe-assets-web/media/pages/profile/standard-widgets/review-widget/orange_star.svg"
        alt="Star"
        width="16"
        height="16"
      />
      <img
        src="https://cdn.thumbtackstatic.com/fe-assets-web/media/pages/profile/standard-widgets/review-widget/orange_star.svg"
        alt="Star"
        width="16"
        height="16"
      />
      <img
        src="https://cdn.thumbtackstatic.com/fe-assets-web/media/pages/profile/standard-widgets/review-widget/orange_star.svg"
        alt="Star"
        width="16"
        height="16"
      />
      <img
        src="https://cdn.thumbtackstatic.com/fe-assets-web/media/pages/profile/standard-widgets/review-widget/orange_star.svg"
        alt="Star"
        width="16"
        height="16"
      />
      <span>118 reviews</span>
    </div>
  </div>
  <div id="reviews-widget-container"></div>
  <div class={styles.ctaContainer}>
    <p class={styles.ctaText}>
      Ready to mount your TV? Book your service now — fast, easy, and
      professional.
    </p>
    <div class={styles.ctaButtons}>
      <QuoteButton
        variant="secondary"
        modalName="BookNow"
        label="Leave Yours Here!"
      />
      <QuoteButton
        variant="primary"
        size="large"
        modalName="BookNow"
        label="Get Your Free Quote"
      />
    </div>
  </div>
</section>
