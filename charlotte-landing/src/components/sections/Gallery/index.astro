---
import PhotoGrid from './PhotoGrid.astro';

interface Props {
    galleryOfWorkData?: any;
    galleryPhotos?: any[];
}

const { galleryOfWorkData, galleryPhotos = [] } = Astro.props;

const title = galleryOfWorkData?.title || "Gallery of Work";
const subTitle = galleryOfWorkData?.subTitle || "Explore our latest professional TV mounting projects.";
const filterTypes = galleryOfWorkData?.types || [];
---

<section class="gallery-of-work" id="gallery">
    <div class="container">
        <header class="gallery-header">
            <h2 class="blockHeading">{title}</h2>
            <p class="section-subtitle">{subTitle}</p>
        </header>

        <PhotoGrid 
            filters={filterTypes} 
            photos={galleryPhotos} 
        />

        <div class="cta-container">
            <p class="cta-text">Like what you see?</p>
            <div class="cta-buttons">
                <button class="cta-button primary" data-open-modal="booking-modal">
                    Get Your Price in 30 Seconds
                </button>
            </div>
        </div>
    </div>
</section>

<style>
    .gallery-of-work {
        padding: 80px 20px;
        background-color: var(--white);
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .gallery-header {
        margin-bottom: 40px;
        text-align: center;
    }

    .section-subtitle {
        font-size: 18px;
        color: var(--gray);
        margin: 12px auto 0 auto;
        max-width: 700px;
    }

    .cta-container {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        margin-top: 40px;
        justify-content: center;
        gap: 16px;
    }

    .cta-text {
        font-weight: 600;
        font-size: 18px;
        line-height: 28px;
        color: var(--foreground);
        text-align: center;
    }

    .cta-button {
        background-color: var(--blue-main);
        color: var(--white);
        border: none;
        padding: 12px 32px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        background-color: var(--blue-hover);
    }

    @media (max-width: 768px) {
        .gallery-header {
            text-align: center;
        }

        .cta-container {
            flex-direction: column;
        }
        
        .gallery-of-work {
            padding: 40px 16px;
        }
    }
</style>
