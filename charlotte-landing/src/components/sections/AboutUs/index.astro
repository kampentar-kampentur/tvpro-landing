---
import ContactForm from "../../ui/ContactForm.astro";

interface Props {
    cityName: string;
    data: any;
}

const { cityName, data } = Astro.props;

const title = data?.title || "What we care about?";
const subTitle = data?.subTitle || "";
const mainText =
    data?.mainTextLeft ||
    "We give you detailed information about our services, so you can confidently choose us. With over six years of experience, we can mount TVs on various surfaces, including drywall, brick, stone, tile, concrete, wood paneling, and exterior surfaces.";
const mainTextRight = data?.mainTextRight || "";

// Form text from Strapi if available
const formTitle = data?.formTitle || "Ready to get started?";
const formSubtitle =
    data?.formSubtitle ||
    "Leave your details and we'll call you back with a quote.";
const submitText = data?.submitButtonText || "Send Request";

const processText = (text: string) => {
    if (!text) return "";
    return text
        .split("\n")
        .map((line) => {
            return line
                .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
                .replace(/\[(.*?)\]/g, '<span class="accent">$1</span>');
        })
        .join("<br />");
};
---

<section class="about-us-section" id="about">
    <div class="about-us-container">
        <header class="section-header">
            <h2 class="section-title" set:html={processText(title)} />
            {
                subTitle && (
                    <p
                        class="section-subtitle"
                        set:html={processText(subTitle)}
                    />
                )
            }
        </header>

        <div class="about-us-split">
            <!-- Text Section -->
            <div class="text-section">
                <div class="section-content">
                    <p set:html={processText(mainText)} />
                    {
                        mainTextRight && (
                            <p set:html={processText(mainTextRight)} />
                        )
                    }
                </div>
            </div>

            <!-- Form Section -->
            <div class="form-section">
                <ContactForm
                    id="aboutUsForm"
                    source="about_us_form"
                    formTitle={formTitle}
                    formSubtitle={formSubtitle}
                    submitText={submitText}
                />
            </div>
        </div>
    </div>
</section>

<style>
    .about-us-section {
        padding: 80px 20px;
        background-color: var(--background);
        color: var(--foreground);
    }

    .about-us-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .about-us-split {
        display: flex;
        gap: 60px;
        align-items: flex-start;
    }

    .text-section {
        flex: 1;
    }

    .section-title {
        font-size: 44px;
        font-weight: 700;
        margin-bottom: 24px;
        color: var(--foreground);
        text-transform: uppercase;
    }

    .section-subtitle {
        font-size: 20px;
        font-weight: 500;
        margin: 0 auto 32px auto;
        color: var(--foreground);
        opacity: 0.8;
        max-width: 800px;
    }

    .section-content {
        font-size: 18px;
        line-height: 1.6;
        color: var(--foreground);
        opacity: 0.9;
    }

    .section-content p {
        margin-bottom: 20px;
    }

    .form-section {
        flex: 0 0 450px;
    }

    .accent {
        color: var(--blue-main);
    }

    @media (max-width: 992px) {
        .about-us-split {
            flex-direction: column;
            gap: 40px;
        }

        .form-section {
            width: 100%;
            flex: none;
        }

        .section-title {
            font-size: 32px;
        }
    }
</style>
