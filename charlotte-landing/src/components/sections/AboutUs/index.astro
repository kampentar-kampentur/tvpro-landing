---
import Button from "../../Button.astro";
import Input from "../../ui/Input.astro";

interface Props {
    cityName: string;
    data: any;
}

const { cityName, data } = Astro.props;

const title = data?.title || "What we care about?";
const subTitle = data?.subTitle || "";
const mainText = data?.mainTextLeft || "We give you detailed information about our services, so you can confidently choose us. With over six years of experience, we can mount TVs on various surfaces, including drywall, brick, stone, tile, concrete, wood paneling, and exterior surfaces.";
const mainTextRight = data?.mainTextRight || "";

// Form text from Strapi if available
const formTitle = data?.formTitle || "Ready to get started?";
const formSubtitle = data?.formSubtitle || "Leave your details and we'll call you back with a quote.";
const namePlaceholder = data?.namePlaceholder || "Your Name";
const phonePlaceholder = data?.phonePlaceholder || "+1 (___) ___-____";
const submitText = data?.submitButtonText || "Send Request";

const processText = (text: string) => {
    if (!text) return "";
    return text.split('\n').map(line => {
        return line
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\[(.*?)\]/g, '<span class="accent">$1</span>');
    }).join('<br />');
};
---

<section class="about-us-section" id="about">
    <div class="about-us-container">
        <header class="section-header">
            <h2 class="section-title" set:html={processText(title)}></h2>
            {subTitle && <p class="section-subtitle" set:html={processText(subTitle)}></p>}
        </header>

        <div class="about-us-split">
            <!-- Text Section -->
            <div class="text-section">
                <div class="section-content">
                    <p set:html={processText(mainText)}></p>
                    {mainTextRight && <p set:html={processText(mainTextRight)}></p>}
                </div>
            </div>

            <!-- Form Section -->
            <div class="form-section">
                <div class="form-container">
                    <h3 class="form-title" set:html={processText(formTitle)}></h3>
                    <p class="form-subtitle" set:html={processText(formSubtitle)}></p>
                    
                    <form id="aboutUsForm" class="contact-form">
                        <Input 
                            label="Full Name" 
                            name="name" 
                            placeholder={namePlaceholder} 
                            class="about-input"
                        />
                        <Input 
                            label="Phone Number *" 
                            name="phone" 
                            type="tel"
                            placeholder={phonePlaceholder} 
                            required 
                            id="aboutUsPhone"
                            class="about-input"
                        />
                        <span id="aboutUsPhoneError" class="phone-error"></span>
                        <Button type="submit" id="aboutUsSubmit" class="submit-button" size="big">{submitText}</Button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const PHONE_REGEX = /^(?:\+1\s?)?\(?[2-9]\d{2}\)?[-.\s]?[2-9]\d{2}[-.s]?\d{4}$/;

        const setupAboutForm = () => {
            const form = document.getElementById("aboutUsForm");
            const phoneInput = document.getElementById("aboutUsPhone");
            const phoneError = document.getElementById("aboutUsPhoneError");
            const submitBtn = document.getElementById("aboutUsSubmit");

            if (!form || !phoneInput) return;

            const formatPhone = (value) => {
                let digits = value.replace(/\D/g, "");
                if (!digits.startsWith("1") && digits.length > 0) digits = "1" + digits;
                digits = digits.slice(0, 11);

                if (digits.length === 0) return "";
                if (digits.length === 1) return "+1";
                if (digits.length <= 4) return `+1 (${digits.slice(1)}`;
                if (digits.length <= 7) return `+1 (${digits.slice(1, 4)}) ${digits.slice(4)}`;
                return `+1 (${digits.slice(1, 4)}) ${digits.slice(4, 7)}-${digits.slice(7)}`;
            };

            phoneInput.addEventListener("focus", () => {
                if (!phoneInput.value) phoneInput.value = "+1 ";
            });

            phoneInput.addEventListener("input", (e) => {
                const cursor = phoneInput.selectionStart;
                const oldLen = phoneInput.value.length;
                phoneInput.value = formatPhone(phoneInput.value);
                const newLen = phoneInput.value.length;
                let nextPos = (cursor || 0) + (newLen - oldLen);
                phoneInput.setSelectionRange(nextPos, nextPos);
            });

            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                
                const formData = new FormData(form);
                const name = formData.get("name")?.toString().trim() || "";
                let phone = formData.get("phone")?.toString() || "";

                if (!phone.startsWith("+1")) phone = "+1" + phone;

                if (!PHONE_REGEX.test(phone)) {
                    if (phoneError) phoneError.textContent = "Invalid phone number";
                    return;
                }

                if (phoneError) phoneError.textContent = "";
                
                if (submitBtn) {
                    const originalText = submitBtn.textContent;
                    submitBtn.textContent = "Sending...";
                    submitBtn.disabled = true;

                    // Get UTM params from sessionStorage
                    let utmParams = {};
                    try {
                        const raw = sessionStorage.getItem('utm_params');
                        utmParams = raw ? JSON.parse(raw) : {};
                    } catch (e) {}

                    const citySlug = window.location.pathname.split("/").filter(Boolean).pop() || "chicago";

                    const payload = {
                        data: {
                            name,
                            phone,
                            city: citySlug,
                            source: 'about_us_form',
                            ...utmParams
                        }
                    };

                    try {
                        const baseUrl = 'https://strapi-dev-e587.up.railway.app';
                        const response = await fetch(`${baseUrl}/api/book-now`, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(payload)
                        });

                        if (response.ok) {
                            window.location.href = "/see-you-soon";
                        } else {
                            console.error("Submission failed");
                            alert("Submission failed. Please try again.");
                            submitBtn.textContent = originalText;
                            submitBtn.disabled = false;
                        }
                    } catch (err) {
                        console.error("Error submitting form:", err);
                        alert("An error occurred. Please try again.");
                        submitBtn.textContent = originalText;
                        submitBtn.disabled = false;
                    }
                }
            });
        };

        setupAboutForm();
        document.addEventListener("astro:page-load", setupAboutForm);
    })();
</script>

<style>
    .about-us-section {
        padding: 80px 20px;
        background-color: var(--background);
        color: var(--foreground);
    }

    .about-us-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .about-us-split {
        display: flex;
        gap: 60px;
        align-items: flex-start;
    }

    .text-section {
        flex: 1;
    }

    .section-title {
        font-size: 44px;
        font-weight: 700;
        margin-bottom: 24px;
        color: var(--foreground);
        text-transform: uppercase;
    }

    .section-subtitle {
        font-size: 20px;
        font-weight: 500;
        margin: 0 auto 32px auto;
        color: var(--foreground);
        opacity: 0.8;
        max-width: 800px;
    }

    .section-content {
        font-size: 18px;
        line-height: 1.6;
        color: var(--foreground);
        opacity: 0.9;
    }

    .section-content p {
        margin-bottom: 20px;
    }

    .form-section {
        flex: 0 0 450px;
    }

    .form-container {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 40px;
        border-radius: 32px;
        backdrop-filter: blur(20px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3), 0 0 30px rgba(13, 100, 160, 0.1);
    }

    .form-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--foreground);
    }

    .form-subtitle {
        font-size: 14px;
        margin-bottom: 32px;
        opacity: 0.7;
        line-height: 1.5;
    }

    .accent {
        color: var(--blue-main);
    }

    .about-input {
        --input-bg: rgba(255, 255, 255, 0.05);
        --input-border: rgba(255, 255, 255, 0.1);
        --input-text: #fff;
        --input-placeholder: rgba(255, 255, 255, 0.4);
        margin-bottom: 12px;
    }

    .phone-error {
        display: block;
        color: #ff4d4f;
        font-size: 12px;
        margin-top: -4px;
        margin-bottom: 12px;
        min-height: 16px;
    }

    .submit-button {
        width: 100%;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 992px) {
        .about-us-split {
            flex-direction: column;
            gap: 40px;
        }

        .form-section {
            width: 100%;
            flex: none;
        }

        .section-title {
            font-size: 32px;
        }
    }
</style>
