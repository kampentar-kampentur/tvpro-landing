---
const services = [
    {
        title: "WIRE CONCEALMENT",
        description: "Would you like to hide your wires?",
        image: "/chicago/images/extra-services/concealment.webp",
    },
    {
        title: "FIREPLACE TV",
        description: "We mount TVs anywhere, even above fireplaces",
        image: "/chicago/images/extra-services/fireplace.webp",
    },
    {
        title: "SOUNDBAR",
        description: "Installation on the wall under the TV",
        image: "/chicago/images/extra-services/soundbar.webp",
    },
    {
        title: "VIDEO WALL",
        description:
            "Seamless multi-display integration for the ultimate viewing experience",
        image: "/chicago/images/extra-services/videowall.webp",
    },
    {
        title: "HOME THEATER",
        description: "Installation and connection",
        image: "/chicago/images/extra-services/home-theater.webp",
    },
];
---

<section class="services-section">
    <header class="services-header">
        <h2 class="services-heading">Additional Services</h2>
    </header>
    <div class="desktop-grid">
        {
            services.map((service) => (
                <article class="service-card" data-open-modal="booking-modal">
                    <div class="service-card-inner">
                        <div class="image-wrapper">
                            <img
                                src={service.image}
                                alt={service.title}
                                loading="lazy"
                                width="160"
                                height="160"
                            />
                        </div>
                        <div class="text-content">
                            <h3 class="service-title">{service.title}</h3>
                            <p class="service-description">
                                {service.description}
                            </p>
                        </div>
                    </div>
                </article>
            ))
        }
    </div>
</section>

<style>
    .services-section {
        background-color: #f3f4f6;
        overflow-x: hidden;
        width: 100%;
        padding-top: 32px;
        padding-bottom: 32px;
    }

    .services-header {
        text-align: center;
        padding: 0 32px;
    }

    .services-heading {
        font-size: 32px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        color: #000;
        margin-bottom: 0;
    }

    .desktop-grid {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 32px;
        padding: 32px;
        /* max-width: 1280px; */
        margin: 0 auto;
    }

    .service-card {
        position: relative;
        width: 240px;
        height: 320px;
        background-color: #ffffff;
        border-radius: 16px;
        box-shadow:
            0 10px 15px -3px rgba(0, 0, 0, 0.1),
            0 4px 6px -2px rgba(0, 0, 0, 0.05);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        cursor: pointer;
        overflow: hidden;
    }

    .service-card:hover {
        transform: scale(1.05) translateY(-4px);
    }

    .service-card-inner {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 16px;
    }

    .image-wrapper {
        position: relative;
        width: 160px;
        height: 160px;
        border-radius: 9999px;
        overflow: hidden;
    }

    .image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .text-content {
        text-align: center;
        margin-top: 16px;
    }

    .service-title {
        font-size: 18px;
        font-weight: 600;
        color: #000000;
        margin-bottom: 4px;
        line-height: 1.25;
        text-transform: uppercase;
    }

    .service-description {
        color: #6b7280;
        font-size: 14px;
        line-height: 1.25;
        margin: 0;
    }

    @media (max-width: 768px) {
        .desktop-grid {
            padding: 32px 16px;
            gap: 24px;
        }

        .service-card {
            width: 320px;
            height: 320px;
            max-width: 100%;
        }
    }
</style>
