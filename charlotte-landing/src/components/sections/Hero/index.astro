---
import Button from "../../Button.astro";
import ImageWrapper from "../../ImageWrapper.astro";

interface Props {
    cityName: string;
    data?: any;
}

const { cityName, data } = Astro.props;

const formatText = (text: string) => {
    if (!text) return "";
    return text.split('\n').map((line) => {
        // [accent text] -> <span class="accent">
        // **bold text** -> <strong>
        return line.replace(/\[(.*?)\]/g, '<span class="accent">$1</span>')
                   .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    }).join('<br />');
};

const title = formatText(data?.title) || `Premium TV Mounting <br class="br-desktop" /> Service In ${cityName}`;
const subTitle = formatText(data?.subTitle) || "Take a <span class=\"hero-quiz-link\" data-open-modal=\"booking-modal\">brief quiz</span> and get <b>$30 off</b> your quote";
---

<section class="hero">
    <div class="hero-background">
        {data?.background ? (
            <ImageWrapper media={data.background} className="hero-bg-wrapper" priority={true} />
        ) : (
            <div class="hero-bg-image"></div>
        )}
        <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
        <h1 class="hero-title" set:html={title} />
        <p class="hero-subtitle" set:html={subTitle} />
        <Button data-open-modal="booking-modal" size="huge" class="hero-cta">Unlock $30 Off</Button>
    </div>
</section>

<style>
    .hero {
        position: relative;
        height: 80vh; /* Increased slightly */
        min-height: 550px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .hero-background {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .hero-bg-image, .hero-bg-wrapper {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-bg-image {
        background-image: url("/hero-bg.webp");
        background-position: center;
        background-size: cover;
    }

    .hero-bg-wrapper :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.45); /* Slightly more contrast */
    }

    .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        color: var(--foreground);
        padding: 0 1.5rem;
        max-width: 900px;
    }

    .hero-title {
        font-size: 42px; /* Increased */
        font-weight: 900;
        text-transform: uppercase;
        line-height: 1.1;
        text-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);
        margin-bottom: 24px;
    }

    .br-desktop {
        display: none;
    }

    .hero-subtitle {
        font-size: 1.25rem; /* Increased */
        margin-bottom: 3.5rem;
        font-weight: 500;
        opacity: 0.95;
    }

    .hero-quiz-link {
        color: var(--blue-main);
        font-weight: 800;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 4px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .hero-quiz-link:hover {
        color: #93c5fd;
        text-shadow: 0 0 15px rgba(96, 165, 250, 0.4);
    }

    .hero-cta {
        background: linear-gradient(135deg, var(--blue-main) 0%, #1d4ed8 100%) !important;
        box-shadow: 0 12px 35px rgba(37, 99, 235, 0.4) !important;
        transform: scale(1.05);
        animation: pulse 2.5s infinite;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .hero-cta:hover {
        transform: scale(1.1) translateY(-5px) !important;
        box-shadow: 0 20px 45px rgba(37, 99, 235, 0.5) !important;
    }

    @keyframes pulse {
        0% { transform: scale(1.05); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1.05); }
    }

    @media (min-width: 768px) {
        .hero {
            height: 90vh; /* More impact on desktop */
        }
        .hero-bg-image, .hero-bg-wrapper {
            transform: scale(1.4) translate(-6px, 95px);
        }
        .hero-title {
            font-size: 64px;
        }
        .hero-subtitle {
            font-size: 1.75rem;
        }
        .br-desktop {
            display: block;
        }
    }

    @media (min-width: 1024px) {
        .hero-title {
            font-size: 82px;
            margin-bottom: 32px;
        }
    }
    main {
        padding-top: 70px;
    }
</style>
