---
import Button from "../../Button.astro";

interface Props {
    cityName: string;
}

const { cityName } = Astro.props;
---

<section class="cta-section">
    <div class="cta-content">
        <h2 class="cta-title">Ready to Transform Your Home?</h2>
        <p class="cta-description">
            Join thousands of happy customers in {cityName}. Secure, professional, and guaranteed installation.
        </p>
        <Button href="/quiz?from=chicago" variant="secondary" size="big">Book Same-Day Service</Button>
    </div>
</section>

<style>
    .cta-section {
        padding: 6rem 1rem;
        background: linear-gradient(135deg, #0d1b3e 0%, #0d64a0 100%);
        color: white;
        text-align: center;
    }

    .cta-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .cta-title {
        font-size: 2.25rem;
        font-weight: 900;
        margin-bottom: 2rem;
        text-transform: uppercase;
        letter-spacing: -0.01em;
    }

    .cta-description {
        font-size: 1.25rem;
        margin-bottom: 3rem;
        opacity: 0.9;
        line-height: 1.6;
    }

    @media (min-width: 768px) {
        .cta-title {
            font-size: 3rem;
        }
        .cta-description {
            font-size: 1.5rem;
        }
    }
</style>

