---
import Button from "../../Button.astro";
import Input from "../../ui/Input.astro";

interface Props {
    cityName: string;
}

const { cityName } = Astro.props;
---

<form class="booking-form">
    <Input
        label="Full Name"
        name="name"
        placeholder="Enter your name *"
        required
    />
    <Input
        label="Phone Number *"
        name="phone"
        type="tel"
        placeholder="Enter your number *"
        required
    />
    <div class="discount-banner">
        <p class="discount-label">Installing 2 or more TVs?</p>
        <p class="discount-text">
            Let the manager know to receive a multi-TVs
            <span class="discount-word">DISCOUNT</span>:
            <span class="discount-percent">10% OFF</span> for 2 TVs,
            <span class="discount-percent">15% OFF</span> for 3,
            <span class="discount-percent">20% OFF</span> for 4 or more.
        </p>
    </div>
    <p class="form-privacy">
        No spam. Your data is used strictly for scheduling your appointment.
    </p>

    <Button type="submit" class="submit-button" size="big" disabled>Send Request</Button>
</form>

<style>
    .booking-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 20px 0;
        width: 100%;
    }

    .discount-banner {
        border: 1px solid var(--gray-extra-light);
        background-color: var(--gray-extra-light);
        border-radius: 12px;
        padding: 24px;
        align-items: flex-start;
        text-align: start;
        margin-top: 20px;
    }

    .discount-label {
        font-size: 20px;
        line-height: 28px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .discount-text {
        font-size: 14px;
        line-height: 20px;
    }

    .discount-word {
        font-weight: bold;
    }

    .discount-percent {
        font-weight: bold;
        color: #fa0004;
    }

    @media (max-width: 980px) {
        .discount-banner {
            padding: 16px;
        }
        .discount-label {
            font-size: 16px;
            line-height: 20px;
            margin: 0;
        }
    }

    .form-privacy {
        font-size: 12px;
        line-height: 16px;
        color: var(--gray);
        text-align: center;
        margin-top: 20px;
    }

    .submit-button {
        width: 100%;
        height: 52px;
        border-radius: 36px;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }
</style>

<script>
    function setupBookingForm() {
        const form = document.querySelector(".booking-form") as HTMLFormElement;
        if (!form) return;

        const nameInput = form.querySelector('input[name="name"]') as HTMLInputElement;
        const phoneInput = form.querySelector('input[name="phone"]') as HTMLInputElement;
        const submitBtn = form.querySelector(".submit-button") as HTMLButtonElement;
        let isSubmitting = false;

        if (!nameInput || !phoneInput || !submitBtn) return;

        function formatUSPhone(raw: string) {
            if (!raw) return '';
            let digits = raw.replace(/\D/g, '');
            if (digits.length > 10 && digits.startsWith('1')) {
                digits = digits.slice(1);
            }
            if (digits.length === 0) return '';
            if (digits.length <= 3) return `(${digits}`;
            if (digits.length <= 6) return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
            return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6, 10)}`;
        }

        const validatePhone = (phone: string) => {
            const digits = phone.replace(/\D/g, '');
            return digits.length === 10 || (digits.length === 11 && digits.startsWith('1'));
        };

        const getUtmParams = () => {
            const params = new URLSearchParams(window.location.search);
            const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
            const utms: Record<string, string> = {};
            utmKeys.forEach(key => {
                const val = params.get(key);
                if (val) utms[key] = val;
            });
            return utms;
        };

        const updateButtonState = () => {
            const name = nameInput.value.trim();
            const phone = phoneInput.value;
            const isValid = name.length > 0 && validatePhone(phone);
            submitBtn.disabled = isSubmitting || !isValid;
        };

        form.addEventListener("input", (e) => {
            if (e.target === phoneInput) {
                const digits = phoneInput.value.replace(/\D/g, '');
                phoneInput.value = formatUSPhone(digits);
            }
            updateButtonState();
        });

        form.addEventListener("change", updateButtonState);

        const handleSubmit = async (e?: Event) => {
            if (e) e.preventDefault();
            if (submitBtn.disabled) return;

            const name = nameInput.value.trim();
            const phone = phoneInput.value;

            if (!name || !validatePhone(phone)) {
                return;
            }

            const originalText = submitBtn.textContent;
            submitBtn.textContent = "Sending...";
            isSubmitting = true;
            updateButtonState();

            try {
                // @ts-ignore
                const apiUrl = import.meta.env.PUBLIC_STRAPI_URL || "https://strapi-production-20d6.up.railway.app";
                const path = window.location.pathname;
                const pathParts = path.split('/').filter(part => part !== "");
                const city = pathParts[0] || 'chicago';

                const response = await fetch(`${apiUrl}/api/book-now`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        data: {
                            name,
                            phone,
                            source: 'booking_form_modal',
                            city,
                            ...getUtmParams(),
                        }
                    }),
                });

                if (response.ok) {
                    if (typeof dataLayer !== 'undefined') {
                        // @ts-ignore
                        dataLayer.push({
                            event: 'form_send_ok',
                            'user_data.phone_number': phone.replace(/\D/g, ''),
                        });
                    }
                    if (typeof gtag !== 'undefined') {
                        // @ts-ignore
                        gtag('event', 'conversion', { 'send_to': 'AW-17416148778/aAZCCNeF9vsaEKqu1fBA' });
                    }

                    sessionStorage.setItem('quiz_return_url', '/chicago/');
                    window.location.href = "/see-you-soon";
                } else {
                    const errorData = await response.json();
                    console.error("Form submission error:", errorData);
                    alert("An error occurred. Please try again.");
                    submitBtn.textContent = originalText;
                    isSubmitting = false;
                    updateButtonState();
                }
            } catch (error) {
                console.error("Error submitting form:", error);
                alert("An error occurred. Please try again.");
                submitBtn.textContent = originalText;
                isSubmitting = false;
                updateButtonState();
            }
        };

        submitBtn.addEventListener("click", handleSubmit);
        
        form.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                if (!submitBtn.disabled) handleSubmit();
            }
        });

        updateButtonState();
    }

    setupBookingForm();
    document.addEventListener("astro:page-load", setupBookingForm);
</script>
