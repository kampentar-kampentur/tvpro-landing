---
import Button from "../../Button.astro";
import Input from "../../ui/Input.astro";

interface Props {
    cityName: string;
}

const { cityName } = Astro.props;
---

<form class="booking-form">
    <Input
        label="Full Name"
        name="name"
        placeholder="Enter your name *"
        required
    />
    <Input
        label="Phone Number *"
        name="phone"
        type="tel"
        placeholder="Enter your number *"
        required
    />
    <div class="discount-banner">
        <p class="discount-label">Installing 2 or more TVs?</p>
        <p class="discount-text">
            Let the manager know to receive a multi-TVs
            <span class="discount-word">DISCOUNT</span>:
            <span class="discount-percent">10% OFF</span> for 2 TVs,
            <span class="discount-percent">15% OFF</span> for 3,
            <span class="discount-percent">20% OFF</span> for 4 or more.
        </p>
    </div>
    <p class="form-privacy">
        No spam. Your data is used strictly for scheduling your appointment.
    </p>

    <Button type="submit" class="submit-button" size="big">Send Request</Button>
</form>

<style>
    .booking-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 20px 0;
        width: 100%;
    }

    .discount-banner {
        border: 1px solid var(--gray-extra-light);
        background-color: var(--gray-extra-light);
        border-radius: 12px;
        padding: 24px;
        align-items: flex-start;
        text-align: start;
        margin-top: 20px;
    }

    .discount-label {
        font-size: 20px;
        line-height: 28px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .discount-text {
        font-size: 14px;
        line-height: 20px;
    }

    .discount-word {
        font-weight: bold;
    }

    .discount-percent {
        font-weight: bold;
        color: #fa0004;
    }

    @media (max-width: 980px) {
        .discount-banner {
            padding: 16px;
        }
        .discount-label {
            font-size: 16px;
            line-height: 20px;
            margin: 0;
        }
    }

    .form-privacy {
        font-size: 12px;
        line-height: 16px;
        color: var(--gray);
        text-align: center;
        margin-top: 20px;
    }

    .submit-button {
        width: 100%;
        height: 52px;
        border-radius: 36px;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }
</style>

<script is:inline>
    (function () {
        function setupBookingForm() {
            const form = document.querySelector(".booking-form");
            if (!form) return;

            const submitBtn = form.querySelector(".submit-button");
            const phoneInput = form.querySelector('input[name="phone"]');

            const PHONE_REGEX =
                /^(?:\+1\s?)?\(?[2-9]\d{2}\)?[-.\s]?[2-9]\d{2}[-.s]?\d{4}$/;

            const formatPhone = (value) => {
                let digits = value.replace(/\D/g, "");
                if (!digits.startsWith("1") && digits.length > 0)
                    digits = "1" + digits;
                digits = digits.slice(0, 11);

                if (digits.length === 0) return "";
                if (digits.length === 1) return "+1";
                if (digits.length <= 4) return `+1 (${digits.slice(1)}`;
                if (digits.length <= 7)
                    return `+1 (${digits.slice(1, 4)}) ${digits.slice(4)}`;
                return `+1 (${digits.slice(1, 4)}) ${digits.slice(4, 7)}-${digits.slice(7)}`;
            };

            if (phoneInput) {
                phoneInput.addEventListener("focus", () => {
                    if (!phoneInput.value) phoneInput.value = "+1 ";
                });
                phoneInput.addEventListener("input", () => {
                    phoneInput.value = formatPhone(phoneInput.value);
                });
            }

            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                const formData = new FormData(form);
                const name = formData.get("name")?.toString() || "";
                let phone = formData.get("phone")?.toString() || "";

                if (!phone.startsWith("+1")) phone = "+1" + phone;

                if (!PHONE_REGEX.test(phone)) {
                    alert("Invalid phone number");
                    return;
                }

                if (submitBtn) {
                    const originalText = submitBtn.textContent;
                    submitBtn.textContent = "Sending...";
                    submitBtn.disabled = true;

                    const citySlug =
                        window.location.pathname
                            .split("/")
                            .filter(Boolean)
                            .pop() || "chicago";

                    // Get UTM params from sessionStorage
                    let utmParams = {};
                    try {
                        const raw = sessionStorage.getItem("utm_params");
                        utmParams = raw ? JSON.parse(raw) : {};
                    } catch (e) {}

                    const payload = {
                        data: {
                            name,
                            phone,
                            city: citySlug,
                            source: "booking_form_modal",
                            ...utmParams,
                        },
                    };

                    try {
                        const baseUrl =
                            import.meta.env.PUBLIC_STRAPI_URL ||
                            "https://strapi-dev-e587.up.railway.app";
                        const response = await fetch(
                            `${baseUrl}/api/book-now`,
                            {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify(payload),
                            },
                        );

                        if (response.ok) {
                            window.location.href = "/see-you-soon";
                        } else {
                            alert("Submission failed. Please try again.");
                            submitBtn.textContent = originalText;
                            submitBtn.disabled = false;
                        }
                    } catch (err) {
                        console.error("Error submitting form:", err);
                        alert("An error occurred. Please try again.");
                        submitBtn.textContent = originalText;
                        submitBtn.disabled = false;
                    }
                }
            });
        }

        setupBookingForm();
        document.addEventListener("astro:page-load", setupBookingForm);
    })();
</script>
