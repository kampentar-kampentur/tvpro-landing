                    </svg>
                )}
            </div>
            <div class="characteristic-text">
                <h2 class="characteristic-title">{item.title}</h2>
                <p class="characteristic-description">{item.description}</p>
            </div>
        </div>
    ))}
</div>

<style>
    .characteristics {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        width: 90%;
        justify-content: space-around;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 40px;
        margin-top: 20px;
        margin-left: auto;
        margin-right: auto;
    }

    .characteristic-item {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 16px;
        width: 320px;
        max-width: 400px;
        min-height: 80px;
    }

    @media (min-width: 831px) {
        .characteristics {
            max-width: 1330px;
            flex-wrap: nowrap;
            justify-content: space-between;
        }
        .characteristic-item {
            justify-content: flex-start;
        }
        .characteristic-item:nth-child(3) {
            justify-content: flex-end;
        }
    }

    @media (max-width: 830px) {
        .characteristics {
            justify-content: center;
        }
        .characteristic-item {
            justify-content: flex-start;
            width: 85%;
        }
    }

    @media (max-width: 1024px) {
        .characteristics {
            width: 100%;
        }
        .characteristic-icon,
        .characteristic-icon svg {
            width: 50px;
        }
    }

    .characteristic-icon {
        width: 60px;
        height: 50px;
        flex-shrink: 0;
        color: var(--blue-main); /* Project Brand Color */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .characteristic-icon svg {
        width: 100%;
        height: 100%;
        display: block;
        max-height: 50px;
        max-width: 60px;
    }

    .characteristic-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        text-align: left;
    }

    .characteristic-title {
        font-size: 16px;
        font-weight: 900;
        margin: 0;
        line-height: 1.2;
        color: var(--foreground);
    }

    .characteristic-description {
        font-size: 14px;
        color: var(--gray);
        margin: 5px 0 0;
        max-width: 26ch;
        white-space: pre-line;
    }
</style>
