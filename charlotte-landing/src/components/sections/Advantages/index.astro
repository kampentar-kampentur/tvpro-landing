---
const advantages = [
    {
        title: "CLEAR PRICING",
        description: "No Hidden Costs",
        id: "pricing"
    },
    {
        title: "QUALITY WITH A 2-YEAR WARRANTY",
        description: "Trusted Experience, Expertise Protected by Insurance",
        id: "warranty"
    },
    {
        title: "RED CARPET TREATMENT",
        description: "Always Excel Expectations Client is Always Right\nCleaning After the Works",
        id: "treatment"
    }
];
---

