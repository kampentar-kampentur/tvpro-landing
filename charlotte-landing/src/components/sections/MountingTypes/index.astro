---
import MountingCard from "../../ui/MountingCard.astro";

interface Props {
    data?: any;
    cityName?: string;
}

const { data, cityName } = Astro.props;

const title = "Total TVs to mount?";
const subTitle = "Select the number of TVs and get a specialized deal";

const mountingTypes = [
    {
        title: "1 TV",
        description: "(2-Year Warranty)",
        image: "/chicago/images/tvs/1tv.svg",
        href: "/quiz?from=chicago",
    },
    {
        title: "2 TVs",
        description: "(Better Deal)",
        image: "/chicago/images/tvs/2tvs.svg",
        href: "/quiz?from=chicago",
    },
    {
        title: "3 TVs",
        description: "(Bundle Price)",
        image: "/chicago/images/tvs/3tvs.svg",
        href: "/quiz?from=chicago",
    },
    {
        title: "3+ TVs",
        description: "(Best Price)",
        image: "/chicago/images/tvs/3plustvs.svg",
        href: "/quiz?from=chicago",
    },
];

const addons = data?.addons || [];
---

<section class="mounting-types">
    <div class="container">
        <header class="section-header">
            <h2 class="section-title">{title}</h2>
            <p class="section-subtitle">{subTitle}</p>
        </header>

        <div class="cards-grid">
            {
                mountingTypes.map((type: any) => (
                    <div class="mounting-card-wrapper">
                        <MountingCard
                            title={type.title}
                            description={type.description}
                            image={type.image}
                            href={type.href}
                        />
                    </div>
                ))
            }
        </div>

        {
            addons.length > 0 && (
                <div class="addons-container">
                    <h4 class="addons-title">Optional Add-ons</h4>
                    <div class="addons-list">
                        {addons.map((addon: any) => (
                            <a
                                href="/quiz?from=chicago"
                                class="addon-tag"
                                style="text-decoration: none;"
                            >
                                {addon.label || addon}
                            </a>
                        ))}
                    </div>
                </div>
            )
        }
    </div>
</section>

<style>
    .mounting-types {
        padding: 60px 20px;
        background-color: #fff;
    }

    .container {
        width: 100%;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .section-title {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .section-subtitle {
        font-size: 16px;
        color: var(--gray);
    }

    .cards-grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        column-gap: 16px;
        row-gap: 16px;
        max-width: 600px;
        margin: auto;
    }

    .mounting-card-wrapper {
        flex: 1 1 180px;
    }

    /* Add-ons Styles */
    .addons-container {
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .addons-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .addons-list {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
    }

    .addon-tag {
        background: #f6f6f8;
        border: 1px solid #e7e7eb;
        padding: 12px 24px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .addon-tag:hover {
        background: var(--blue-main);
        color: #fff;
        border-color: var(--blue-main);
        transform: translateY(-2px);
    }

    @media (min-width: 1024px) {
        .cards-grid {
            gap: 24px;
        }
    }

    @media (max-width: 600px) {
        .section-title {
            font-size: 28px;
        }
        .cards-grid {
            gap: 12px;
        }
        .mounting-card-wrapper {
            flex: 1 1 140px;
        }
    }
</style>
