---
import Modal from "./Modal.astro";
import Input from "./ui/Input.astro";
import Button from "./Button.astro";
import Checkbox from "./ui/Checkbox.astro";

// This component is included in Layout.astro and handled by global scripts
---

<Modal id="ExitIntentModal" title="Wait! Get $30 OFF" subtitle="Don't leave yet! Claim your discount for your first professional TV installation.">
    <form id="exit-intent-form" class="exit-intent-form">
        <Input 
            label="Full Name" 
            name="name" 
            placeholder="Your name *" 
            required 
            class="exit-input"
        />
        <Input 
            label="Phone Number *" 
            name="phone" 
            type="tel"
            id="exit-intent-phone"
            placeholder="+1 (___) ___-____" 
            required 
            class="exit-input"
        />
        
        <div class="form-footer">
            <Checkbox 
                id="exit-terms-checkbox" 
                name="terms" 
                required 
                label='I agree to receive SMS from TVPro Handy Services LLC regarding appointments and service updates. <p><a href="/privacy-policy" target="_blank">Privacy Policy</a> and <a href="/terms" target="_blank" style="margin-left: 8px">Terms of Service</a></p>'
            />
            
            <Button type="submit" id="exitIntentSubmit" size="big" class="submit-btn">Claim My $30 Off</Button>
        </div>

        <button type="button" class="no-thanks" data-close-modal="ExitIntentModal">
            No thanks, I'll pay full price
        </button>
    </form>
</Modal>

<style>
    .exit-intent-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 20px 0;
        width: 100%;
    }

    .form-footer {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 10px;
    }

    .submit-btn {
        width: 100%;
        height: 52px;
        border-radius: 36px;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }

    .no-thanks {
        margin-top: 24px;
        background: none;
        border: none;
        color: var(--gray);
        font-size: 14px;
        text-decoration: underline;
        cursor: pointer;
        align-self: center;
        transition: color 0.2s;
        opacity: 0.7;
    }

    .no-thanks:hover {
        color: var(--foreground);
        opacity: 1;
    }

    .exit-input {
        margin-bottom: 0;
    }

    @media (max-width: 600px) {
        :global(#ExitIntentModal .modal-title) {
            font-size: 32px;
        }
    }
</style>

<script is:inline>
    // Logic for form submission
    function setupExitForm() {
        const form = document.getElementById('exit-intent-form');
        const phoneInput = document.getElementById('exit-intent-phone');
        const submitBtn = document.getElementById('exitIntentSubmit');
        const PHONE_REGEX = /^(?:\+1\s?)?\(?[2-9]\d{2}\)?[-.\s]?[2-9]\d{2}[-.s]?\d{4}$/;

        if (!form || !phoneInput) return;

        const formatPhone = (value) => {
            let digits = value.replace(/\D/g, "");
            if (!digits.startsWith("1") && digits.length > 0) digits = "1" + digits;
            digits = digits.slice(0, 11);

            if (digits.length === 0) return "";
            if (digits.length === 1) return "+1";
            if (digits.length <= 4) return `+1 (${digits.slice(1)}`;
            if (digits.length <= 7) return `+1 (${digits.slice(1, 4)}) ${digits.slice(4)}`;
            return `+1 (${digits.slice(1, 4)}) ${digits.slice(4, 7)}-${digits.slice(7)}`;
        };

        phoneInput.addEventListener("focus", () => {
            if (!phoneInput.value) phoneInput.value = "+1 ";
        });

        phoneInput.addEventListener("input", () => {
            phoneInput.value = formatPhone(phoneInput.value);
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(form);
            const name = formData.get("name")?.toString() || "";
            let phone = formData.get("phone")?.toString() || "";

            if (!phone.startsWith("+1")) phone = "+1" + phone;

            if (!PHONE_REGEX.test(phone)) {
                alert("Invalid phone number");
                return;
            }

            if (submitBtn) {
                const originalText = submitBtn.textContent;
                submitBtn.textContent = "Sending...";
                submitBtn.disabled = true;

                // Get UTM params from sessionStorage
                let utmParams = {};
                try {
                    const raw = sessionStorage.getItem('utm_params');
                    utmParams = raw ? JSON.parse(raw) : {};
                } catch (e) {}

                const citySlug = window.location.pathname.split("/").filter(Boolean).pop() || "charlotte";

                const payload = {
                    data: {
                        name,
                        phone,
                        city: citySlug,
                        source: 'exit_intent_popup',
                        ...utmParams
                    }
                };

                try {
                    const baseUrl = 'https://strapi-dev-e587.up.railway.app';
                    const response = await fetch(`${baseUrl}/api/book-now`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        window.location.href = "/see-you-soon";
                    } else {
                        alert("Submission failed. Please try again.");
                        submitBtn.textContent = originalText;
                        submitBtn.disabled = false;
                    }
                } catch (err) {
                    console.error("Error submitting form:", err);
                    alert("An error occurred. Please try again.");
                    submitBtn.textContent = originalText;
                    submitBtn.disabled = false;
                }
            }
        });
    }

    // Initialize
    setupExitForm();
    document.addEventListener('astro:page-load', setupExitForm);
</script>
