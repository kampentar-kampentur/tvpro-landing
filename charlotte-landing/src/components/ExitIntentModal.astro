---
import Modal from "./Modal.astro";
import Input from "./ui/Input.astro";
import Button from "./Button.astro";
import Checkbox from "./ui/Checkbox.astro";

const apiUrl = import.meta.env.PUBLIC_STRAPI_URL || "https://strapi-production-20d6.up.railway.app";
---

<Modal
    id="ExitIntentModal"
    title="Wait! Get $30 OFF"
    subtitle="Don't leave yet! Claim your discount for your first professional TV installation."
>
    <form id="exit-intent-form" class="exit-intent-form">
        <Input
            id="exitIntentName"
            label="Full Name"
            name="name"
            placeholder="Your name *"
            required
            class="exit-input"
        />
        <Input
            label="Phone Number *"
            name="phone"
            type="tel"
            id="exit-intent-phone"
            placeholder="+1 (___) ___-____"
            required
            class="exit-input"
        />

        <div class="form-footer">
            <Checkbox
                id="exit-terms-checkbox"
                name="terms"
                required
                label='I agree to receive SMS from TVPro Handy Services LLC regarding appointments and service updates. <a href="/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy Policy</a> and <a href="/terms" target="_blank" rel="noopener noreferrer" style="margin-left: 8px">Terms of Service</a>'
            />

            <Button
                type="submit"
                id="exitIntentSubmit"
                size="big"
                class="submit-btn"
                disabled>Claim My $30 Off</Button
            >
        </div>

        <button
            type="button"
            class="no-thanks"
            data-close-modal="ExitIntentModal"
        >
            No thanks, I'll pay full price
        </button>
    </form>
</Modal>

<style>
    .exit-intent-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 20px 0;
        width: 100%;
    }

    .form-footer {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 10px;
    }

    .submit-btn {
        width: 100%;
        height: 52px;
        border-radius: 36px;
        font-weight: 700;
        font-size: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }

    .no-thanks {
        margin-top: 24px;
        background: none;
        border: none;
        color: var(--gray);
        font-size: 14px;
        text-decoration: underline;
        cursor: pointer;
        align-self: center;
        transition: color 0.2s;
        opacity: 0.7;
    }

    .no-thanks:hover {
        color: var(--foreground);
        opacity: 1;
    }

    .exit-input {
        margin-bottom: 0;
    }

    @media (max-width: 600px) {
        :global(#ExitIntentModal .modal-title) {
            font-size: 32px;
        }
    }
</style>

<script is:inline define:vars={{ apiUrl }}>
    (function () {
        const setupExitForm = () => {
            const form = document.getElementById("exit-intent-form");
            const nameInput = document.getElementById("exitIntentName");
            const phoneInput = document.getElementById("exit-intent-phone");
            const termsCheckbox = document.getElementById("exit-terms-checkbox");
            const submitBtn = document.getElementById("exitIntentSubmit");
            let isSubmitting = false;

            if (!form || !phoneInput || !submitBtn || !termsCheckbox) return;

            const formatPhone = (value) => {
                let digits = value.replace(/\D/g, "");
                if (digits.length > 10 && digits.startsWith("1")) {
                    digits = digits.slice(1);
                }
                if (digits.length === 0) return "";
                if (digits.length <= 3) return `(${digits}`;
                if (digits.length <= 6)
                    return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
                return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6, 10)}`;
            };

            const validatePhone = (phone) => {
                const digits = phone.replace(/\D/g, "");
                return (
                    digits.length === 10 ||
                    (digits.length === 11 && digits.startsWith("1"))
                );
            };

            const getUtmParams = () => {
                let utms = {};
                try {
                    const raw = sessionStorage.getItem("utm_params");
                    utms = raw ? JSON.parse(raw) : {};
                } catch (e) {}
                
                // Also check search params as fallback
                const params = new URLSearchParams(window.location.search);
                const utmKeys = ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content"];
                utmKeys.forEach(key => {
                    const val = params.get(key);
                    if (val) utms[key] = val;
                });
                return utms;
            };

            const updateButtonState = () => {
                const name = nameInput?.value?.trim() || "";
                const phone = phoneInput.value;
                const terms = termsCheckbox.checked;
                const isPhoneValid = validatePhone(phone);
                const isValid = name.length > 0 && isPhoneValid && terms;

                submitBtn.disabled = isSubmitting || !isValid;
            };

            form.addEventListener("input", (e) => {
                if (e.target === phoneInput) {
                    const digits = phoneInput.value.replace(/\D/g, "");
                    phoneInput.value = formatPhone(digits);
                }
                updateButtonState();
            });

            form.addEventListener("change", updateButtonState);

            const handleSubmit = async (e) => {
                if (e) e.preventDefault();
                if (submitBtn.disabled) return;

                const name = nameInput?.value?.trim() || "";
                const phone = phoneInput.value;

                if (!name || !validatePhone(phone) || !termsCheckbox.checked) {
                    return;
                }

                const originalText = submitBtn.textContent;
                submitBtn.textContent = "Sending...";
                isSubmitting = true;
                updateButtonState();

                const citySlug =
                    window.location.pathname.split("/").filter(Boolean).pop() ||
                    "chicago";

                try {
                    const response = await fetch(`${apiUrl}/api/book-now`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            data: {
                                name,
                                phone,
                                city: citySlug,
                                source: "exit_intent_popup",
                                ...getUtmParams(),
                            },
                        }),
                    });

                    if (response.ok) {
                        if (typeof dataLayer !== "undefined") {
                            dataLayer.push({
                                event: "form_send_ok",
                                "user_data.phone_number": phone.replace(/\D/g, ""),
                            });
                        }
                        if (typeof gtag !== "undefined") {
                            gtag("event", "conversion", {
                                send_to: "AW-17416148778/aAZCCNeF9vsaEKqu1fBA",
                            });
                        }

                        sessionStorage.setItem('quiz_return_url', '/chicago/');
                        window.location.href = "/see-you-soon";
                    } else {
                        const errorData = await response.json();
                        console.error("Form submission error:", errorData);
                        alert("Submission failed. Please try again.");
                        submitBtn.textContent = originalText;
                        isSubmitting = false;
                        updateButtonState();
                    }
                } catch (err) {
                    console.error("Error submitting form:", err);
                    alert("An error occurred. Please try again.");
                    submitBtn.textContent = originalText;
                    isSubmitting = false;
                    updateButtonState();
                }
            };

            submitBtn.addEventListener("click", handleSubmit);
            
            form.addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    if (!submitBtn.disabled) handleSubmit();
                }
            });

            updateButtonState();
        };

        setupExitForm();
        document.addEventListener("astro:page-load", setupExitForm);
    })();
</script>
