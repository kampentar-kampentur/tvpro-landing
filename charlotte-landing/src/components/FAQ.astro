---
interface FAQItem {
    question: string;
    answer: string;
}

interface Props {
    title?: string;
    subTitle?: string;
    faqs: FAQItem[];
}

const { 
    title = "Frequently Asked Questions", 
    subTitle = "", 
    faqs = [] 
} = Astro.props;

const processText = (text: string) => {
    if (!text) return "";
    return text.split('\n').map(line => {
        return line
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\[(.*?)\]/g, '<span class="accent">$1</span>');
    }).join('<br />');
};

const structuredFAQ = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(({ question, answer }) => ({
        "@type": "Question",
        "name": question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": answer,
        },
    })),
};
---

<section class="faq-section" id="faq">
    <div class="faq-container">
        <header class="section-header">
            <h2 class="section-title" set:html={processText(title)}></h2>
            {subTitle && <p class="section-subtitle" set:html={processText(subTitle)}></p>}
        </header>

        {faqs.length > 0 ? (
            <div class="faq-content">
                {faqs.map((item, index) => (
                    <div class="faq-item">
                        <input
                            type="radio"
                            name="faq-accordion"
                            id={`faq-toggle-${index}`}
                            class="faq-toggle"
                            checked={index === 0}
                        />
                        <label for={`faq-toggle-${index}`} class="faq-question-container">
                            <span class="faq-question" set:html={processText(item.question)}></span>
                            <span class="icon">
                                <svg class="plus-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 4v16M20 12H4" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"/>
                                </svg>
                                <svg class="minus-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M20 12H4" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </label>
                        <div class="faq-answer-wrapper">
                            <p class="faq-answer" set:html={processText(item.answer)}></p>
                        </div>
                    </div>
                ))}
            </div>
        ) : (
            <p class="no-faqs">No FAQs available yet.</p>
        )}
    </div>

    <!-- JSON-LD for SEO -->
    {faqs.length > 0 && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredFAQ)} />
    )}
</section>

<style>
    .faq-section {
        padding: 80px 20px;
        background-color: var(--background);
        color: var(--foreground);
    }

    .faq-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-header {
        margin-bottom: 40px;
        text-align: center;
    }

    .section-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 16px;
        text-transform: uppercase;
    }
    
    @media (min-width: 768px) {
        .section-title {
            font-size: 44px;
        }
    }

    .section-subtitle {
        font-size: 18px;
        opacity: 0.7;
        max-width: 600px;
        margin: 0 auto;
    }

    .faq-content {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 40px;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .faq-item {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 20px;
    }

    .faq-item:last-child {
        border-bottom: none;
    }

    .faq-question-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

    .faq-question {
        font-size: 18px;
        font-weight: 500;
        line-height: 1.4;
        transition: color 0.3s;
    }
    
    @media (min-width: 768px) {
        .faq-question {
            font-size: 20px;
        }
    }

    .icon {
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--blue-main);
        position: relative;
    }

    .plus-icon {
        display: block;
    }

    .minus-icon {
        display: none;
    }

    .faq-toggle {
        display: none;
    }

    .faq-answer-wrapper {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out, margin-top 0.3s ease-out;
        margin-top: 0;
    }

    .faq-answer {
        font-size: 16px;
        line-height: 1.6;
        opacity: 0.8;
    }

    .faq-toggle:checked + .faq-question-container .plus-icon {
        display: none;
    }
    
    .faq-toggle:checked + .faq-question-container .minus-icon {
        display: block;
    }
    
    .faq-toggle:checked + .faq-question-container .faq-question {
        color: var(--blue-main);
    }
    
    .faq-toggle:checked + .faq-question-container + .faq-answer-wrapper {
        max-height: 500px;
        margin-top: 12px;
    }

    @media (max-width: 1024px) {
        .faq-question {
            font-size: 16px;
            line-height: 24px;
        }
        .faq-answer {
            font-size: 14px;
            line-height: 20px;
        }
    }

    .accent {
        color: var(--blue-main);
        font-weight: 600;
    }

    .no-faqs {
        text-align: center;
        opacity: 0.5;
        padding: 40px;
    }
</style>
