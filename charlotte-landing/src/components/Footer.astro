---
interface Props {
    phone?: string;
    hours?: string;
    email?: string;
    phoneLabel?: string;
}

const {
    phone = "(213) 584-4010",
    hours = "8:00 AM - 10:00 PM DAILY",
    email = "tvprohandyservices@gmail.com",
    phoneLabel = "",
} = Astro.props;

const phoneLink = `tel:${phone.replace(/\D/g, "")}`;
---

<style>
    footer {
        background-color: #fff;
        color: var(--foreground);
        padding: 4rem 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-cols: 1fr 1fr;
        gap: 3rem;
    }

    @media (max-width: 768px) {
        .footer-container {
            grid-template-cols: 1fr;
            text-align: center;
        }
    }

    .footer-logo {
        height: 40px;
        width: 82px;
        margin-bottom: 2rem;
    }

    .btn-call {
        display: inline-block;
        background: var(--brand-blue);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 2rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        transition: transform 0.2s;
    }

    .btn-call:hover {
        transform: scale(1.05);
    }

    .footer-heading {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .footer-info {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .footer-info p {
        color: #9ca3af;
    }

    .footer-contact p {
        margin-bottom: 0.5rem;
    }

    @media (min-width: 768px) {
        .footer-info {
            align-items: flex-start;
        }
    }

    .legal-links {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        gap: 2rem;
        font-size: 14px;
        color: #6b7280;
        max-width: 1200px;
        margin: 0 auto;
    }

    .legal-links p {
        color: #9ca3af;
    }

    .legal-links a:hover {
        color: var(--brand-blue);
    }
</style>

<footer>
    <div class="footer-container">
        <div class="footer-info">
            <img
                src="/chicago/logo.svg"
                alt="TVPro Logo"
                class="footer-logo"
                width="82"
                height="40"
            />
            <a href={phoneLink} class="btn-call">Call {phoneLabel || phone}</a>
            <p>Serving Chicago and Surrounding Areas</p>
        </div>

        <div class="footer-contact">
            <h3 class="footer-heading">Contact Us</h3>
            <p>Hours: {hours}</p>
            <p>Email: {email}</p>
            <p>Address: Chicago, IL</p>
        </div>
    </div>

    <div class="legal-links">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms of Use</a>
        <p>© 2026 TVPro Handy Services. All rights reserved.</p>
    </div>
</footer>
