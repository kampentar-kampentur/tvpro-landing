---
interface Props {
    media: any;
    className?: string;
    defaultAlt?: string;
    width?: number;
    height?: number;
    sizes?: string;
    priority?: boolean;
    preferFormat?: 'large' | 'medium' | 'small' | 'thumbnail';
}

const {
    media,
    className,
    defaultAlt,
    width,
    height,
    sizes = "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw",
    priority = false,
    preferFormat
} = Astro.props;

if (!media) return null;

const baseUrl = import.meta.env.PUBLIC_STRAPI_URL || 'https://strapi-dev-e587.up.railway.app';

const formats = media.formats || {};

const getImageUrl = (formatData?: any) => {
    const url = formatData?.url || media.url;
    return url && url.startsWith('http') ? url : `${baseUrl}${url}`;
};

// Logic to select the best format similar to Next.js
const getBestUrl = () => {
    if (preferFormat && formats[preferFormat]) {
        return getImageUrl(formats[preferFormat]);
    }

    if (!formats || Object.keys(formats).length === 0) {
        return getImageUrl();
    }

    const availableFormats = Object.keys(formats)
        .map(key => ({ key, ...formats[key] }))
        .sort((a, b) => a.width - b.width);

    // If we have a specific width requested, try to find the best fit
    if (width) {
        const bestFit = availableFormats.find(f => f.width >= width);
        if (bestFit) return getImageUrl(bestFit);
    }

    // Default to the largest available format
    return getImageUrl(availableFormats[availableFormats.length - 1]);
};

// Generate srcset if multiple formats are available
const getSrcSet = () => {
    if (!formats || Object.keys(formats).length === 0) return undefined;

    return Object.keys(formats)
        .map(key => {
            const f = formats[key];
            return `${getImageUrl(f)} ${f.width}w`;
        })
        .join(', ');
};

const finalUrl = getBestUrl();
const srcSet = getSrcSet();

const altText = media.alternativeText || media.caption || defaultAlt || "";

const finalWidth = width || (media.width ? Math.min(media.width, 1200) : 1200);
const finalHeight = height || (media.width && media.height ? Math.round(finalWidth / (media.width / media.height)) : undefined);
---

<img 
    src={finalUrl} 
    srcset={srcSet}
    sizes={sizes}
    class={className} 
    alt={altText} 
    width={finalWidth} 
    height={finalHeight}
    loading={priority ? "eager" : "lazy"}
    decoding="async"
/>
