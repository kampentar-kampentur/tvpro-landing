---
import Button from "../Button.astro";
import Input from "./Input.astro";

interface Props {
    id?: string;
    source?: string;
    formTitle?: string;
    formSubtitle?: string;
    submitText?: string;
    namePlaceholder?: string;
    phonePlaceholder?: string;
}

const {
    id = "contactForm",
    source = "contact_form",
    formTitle = "Ready to get started?",
    formSubtitle = "Leave your details and we'll call you back with a quote.",
    submitText = "Send Request",
    namePlaceholder = "Your Name",
    phonePlaceholder = "+1 (___) ___-____",
} = Astro.props;
const apiUrl = import.meta.env.PUBLIC_STRAPI_URL || "https://strapi-production-20d6.up.railway.app";
---

<div class="contact-form-container">
    {formTitle && <h3 class="form-title">{formTitle}</h3>}
    {formSubtitle && <p class="form-subtitle">{formSubtitle}</p>}

    <form id={id} class="contact-form" data-source={source}>
        <Input
            id={`${id}Name`}
            label="Full Name"
            name="name"
            placeholder={namePlaceholder}
            class="contact-input"
        />
        <Input
            label="Phone Number *"
            name="phone"
            type="tel"
            placeholder={phonePlaceholder}
            required
            id={`${id}Phone`}
            class="contact-input"
        />
        <span id={`${id}PhoneError`} class="phone-error"></span>
        <Button id={`${id}Submit`} class="submit-button" size="huge" disabled
            >{submitText}</Button
        >
    </form>
</div>

<style>
    .contact-form-container {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.08) 0%,
            rgba(255, 255, 255, 0.03) 100%
        );
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 40px;
        border-radius: 32px;
        backdrop-filter: blur(20px);
        box-shadow:
            0 25px 50px rgba(0, 0, 0, 0.3),
            0 0 30px rgba(13, 100, 160, 0.1);
        width: 100%;
        max-width: 450px;
    }

    .form-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--foreground);
    }

    .form-subtitle {
        font-size: 14px;
        margin-bottom: 32px;
        opacity: 0.7;
        line-height: 1.5;
        color: var(--foreground);
    }

    .contact-form {
        display: flex;
        flex-direction: column;
    }

    :global(.contact-input) {
        margin-bottom: 8px !important;
    }

    .phone-error {
        display: block;
        color: #ff4d4f;
        font-size: 12px;
        margin-top: -4px;
        margin-bottom: 12px;
        min-height: 16px;
    }

    .submit-button {
        width: 100%;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 480px) {
        .contact-form-container {
            padding: 30px 20px;
            border-radius: 24px;
        }

        .form-title {
            font-size: 20px;
        }
    }
</style>

<script is:inline define:vars={{ id, apiUrl }}>
    (function () {
        console.log("ContactForm script initialized for ID:", id);
        
        function formatUSPhone(raw) {
            if (!raw) return "";
            let digits = raw.replace(/\D/g, "");
            if (digits.length > 10 && digits.startsWith("1")) {
                digits = digits.slice(1);
            }
            if (digits.length === 0) return "";
            if (digits.length <= 3) return `(${digits}`;
            if (digits.length <= 6)
                return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
            return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6, 10)}`;
        }

        const validatePhone = (phone) => {
            const digits = phone.replace(/\D/g, "");
            return (
                digits.length === 10 ||
                (digits.length === 11 && digits.startsWith("1"))
            );
        };

        const getUtmParams = () => {
            const params = new URLSearchParams(window.location.search);
            const utmKeys = [
                "utm_source",
                "utm_medium",
                "utm_campaign",
                "utm_term",
                "utm_content",
            ];
            const utms = {};
            utmKeys.forEach((key) => {
                const val = params.get(key);
                if (val) utms[key] = val;
            });
            return utms;
        };

        const setupForm = () => {
            console.log(`[Form:${id}] setting up listeners...`);

            const form = document.getElementById(id);
            const nameInput = document.getElementById(`${id}Name`);
            const phoneInput = document.getElementById(`${id}Phone`);
            const phoneError = document.getElementById(`${id}PhoneError`);
            const submitBtn = document.getElementById(`${id}Submit`);
            let isSubmitting = false;

            if (!form || !phoneInput || !submitBtn) {
                 console.error(`[Form:${id}] Missing elements:`, { form, phoneInput, submitBtn });
                 return;
            }

            const updateButtonState = () => {
                const name = nameInput?.value?.trim() || "";
                const phone = phoneInput.value;
                const isPhoneValid = validatePhone(phone);
                const isValid = name.length > 0 && isPhoneValid;
                
                console.log(`[Form:${id}] State Check:`, { name, phone, isValid, isSubmitting });

                submitBtn.disabled = isSubmitting || !isValid;
                
                if (submitBtn.disabled && !isSubmitting) {
                    submitBtn.style.opacity = "0.5";
                    submitBtn.style.cursor = "not-allowed";
                } else if (isSubmitting) {
                    submitBtn.style.opacity = "0.7";
                    submitBtn.style.cursor = "wait";
                } else {
                    submitBtn.style.opacity = "1";
                    submitBtn.style.cursor = "pointer";
                }
            };

            // Listen for any input changes in the form
            form.addEventListener("input", (e) => {
                if (e.target === phoneInput) {
                    const digits = phoneInput.value.replace(/\D/g, "");
                    phoneInput.value = formatUSPhone(digits);
                }
                updateButtonState();
            });

            form.addEventListener("change", updateButtonState);

            const handleSubmit = async (e) => {
                if (e) e.preventDefault();
                if (submitBtn.disabled) return;

                const name = nameInput?.value?.trim() || "";
                const phone = phoneInput.value;

                if (!name || !validatePhone(phone)) {
                    if (phoneError)
                        phoneError.textContent =
                            "Please provide a valid name and phone number.";
                    return;
                }

                if (phoneError) phoneError.textContent = "";

                const originalText = submitBtn.textContent;
                submitBtn.textContent = "Sending...";
                isSubmitting = true;
                updateButtonState();

                try {
                    const path = window.location.pathname;
                    const pathParts = path.split("/").filter((part) => part !== "");
                    const city = pathParts[0] || "chicago";

                    const response = await fetch(`${apiUrl}/api/book-now`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            data: {
                                name,
                                phone,
                                source:
                                    form.getAttribute("data-source") ||
                                    "contact_form",
                                city,
                                ...getUtmParams(),
                            },
                        }),
                    });

                    if (response.ok) {
                        if (typeof dataLayer !== "undefined") {
                            dataLayer.push({
                                event: "form_send_ok",
                                "user_data.phone_number": phone.replace(/\D/g, ""),
                            });
                        }
                        if (typeof gtag !== "undefined") {
                            gtag("event", "conversion", {
                                send_to: "AW-17416148778/aAZCCNeF9vsaEKqu1fBA",
                            });
                        }

                        window.location.href = "/see-you-soon";
                    } else {
                        const errorData = await response.json();
                        console.error("Form submission error:", errorData);
                        alert("An error occurred. Please try again.");
                        submitBtn.textContent = originalText;
                        isSubmitting = false;
                        updateButtonState();
                    }
                } catch (error) {
                    console.error("Failed to send form:", error);
                    alert("Failed to send request. Please check your connection.");
                    submitBtn.textContent = originalText;
                    isSubmitting = false;
                    updateButtonState();
                }
            };

            submitBtn.addEventListener("click", handleSubmit);

            form.addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    if (!submitBtn.disabled) handleSubmit();
                }
            });

            updateButtonState();
        };

        setupForm();
        document.addEventListener("astro:page-load", setupForm);
    })();
</script>
