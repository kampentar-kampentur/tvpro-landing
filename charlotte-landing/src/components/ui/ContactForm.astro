---
import Button from "../Button.astro";
import Input from "./Input.astro";

interface Props {
    id?: string;
    source?: string;
    formTitle?: string;
    formSubtitle?: string;
    submitText?: string;
}

const { 
    id = "contactForm", 
    source = "contact_form",
    formTitle = "Ready to get started?",
    formSubtitle = "Leave your details and we'll call you back with a quote.",
    submitText = "Send Request"
} = Astro.props;
---

<div class="contact-form-container">
    {formTitle && <h3 class="form-title">{formTitle}</h3>}
    {formSubtitle && <p class="form-subtitle">{formSubtitle}</p>}
    
    <form id={id} class="contact-form" data-source={source}>
        <Input 
            label="Full Name" 
            name="name" 
            placeholder="Your Name" 
            class="contact-input"
        />
        <Input 
            label="Phone Number *" 
            name="phone" 
            type="tel"
            placeholder="+1 (___) ___-____" 
            required 
            id={`${id}Phone`}
            class="contact-input"
        />
        <span id={`${id}PhoneError`} class="phone-error"></span>
        <Button type="submit" id={`${id}Submit`} class="submit-button" size="huge">{submitText}</Button>
    </form>
</div>

<style>
    .contact-form-container {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 40px;
        border-radius: 32px;
        backdrop-filter: blur(20px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3), 0 0 30px rgba(13, 100, 160, 0.1);
        width: 100%;
        max-width: 450px;
    }

    .form-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--white, #fff);
    }

    .form-subtitle {
        font-size: 14px;
        margin-bottom: 32px;
        color: var(--white, #fff);
        opacity: 0.7;
        line-height: 1.5;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .contact-input {
        --input-bg: rgba(255, 255, 255, 0.05);
        --input-border: rgba(255, 255, 255, 0.1);
        --input-text: #fff;
        --input-placeholder: rgba(255, 255, 255, 0.4);
    }

    .phone-error {
        display: block;
        color: #ff4d4f;
        font-size: 12px;
        margin-top: -4px;
        margin-bottom: 8px;
        min-height: 16px;
    }

    .submit-button {
        width: 100%;
        margin-top: 12px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 480px) {
        .contact-form-container {
            padding: 30px 20px;
            border-radius: 24px;
        }
        
        .form-title {
            font-size: 20px;
        }
    }
</style>

<script is:inline define:vars={{ id }}>
    (function() {
        const PHONE_REGEX = /^(?:\+1\s?)?\(?[2-9]\d{2}\)?[-.\s]?[2-9]\d{2}[-.\s]?\d{4}$/;

        const setupForm = () => {
            const form = document.getElementById(id);
            const phoneInput = document.getElementById(`${id}Phone`);
            const phoneError = document.getElementById(`${id}PhoneError`);
            const submitBtn = document.getElementById(`${id}Submit`);

            if (!form || !phoneInput) return;

            const formatPhone = (value) => {
                let digits = value.replace(/\D/g, "");
                if (!digits.startsWith("1") && digits.length > 0) digits = "1" + digits;
                digits = digits.slice(0, 11);

                if (digits.length === 0) return "";
                if (digits.length === 1) return "+1";
                if (digits.length <= 4) return `+1 (${digits.slice(1)}`;
                if (digits.length <= 7) return `+1 (${digits.slice(1, 4)}) ${digits.slice(4)}`;
                return `+1 (${digits.slice(1, 4)}) ${digits.slice(4, 7)}-${digits.slice(7)}`;
            };

            phoneInput.addEventListener("focus", () => {
                if (!phoneInput.value) phoneInput.value = "+1 ";
            });

            phoneInput.addEventListener("input", (e) => {
                const cursor = phoneInput.selectionStart;
                const oldLen = phoneInput.value.length;
                phoneInput.value = formatPhone(phoneInput.value);
                const newLen = phoneInput.value.length;
                let nextPos = (cursor || 0) + (newLen - oldLen);
                phoneInput.setSelectionRange(nextPos, nextPos);
            });

            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                
                const formData = new FormData(form);
                const name = formData.get("name")?.toString().trim() || "";
                let phoneValue = formData.get("phone")?.toString() || "";

                if (!phoneValue.startsWith("+1")) phoneValue = "+1" + phoneValue;

                if (!PHONE_REGEX.test(phoneValue)) {
                    if (phoneError) phoneError.textContent = "Invalid phone number";
                    return;
                }

                if (phoneError) phoneError.textContent = "";
                
                if (submitBtn) {
                    const originalText = submitBtn.textContent;
                    submitBtn.textContent = "Sending...";
                    submitBtn.disabled = true;

                    // Get UTM params from sessionStorage
                    let utmParams = {};
                    try {
                        const raw = sessionStorage.getItem('utm_params');
                        utmParams = raw ? JSON.parse(raw) : {};
                    } catch (err) {}

                    const citySlug = window.location.pathname.split("/").filter(Boolean).pop() || "chicago";
                    const source = form.getAttribute('data-source') || "contact_form";

                    const payload = {
                        data: {
                            name,
                            phone: phoneValue,
                            city: citySlug,
                            source: source,
                            ...utmParams
                        }
                    };

                    try {
                        const baseUrl = 'https://strapi-dev-e587.up.railway.app';
                        const response = await fetch(`${baseUrl}/api/book-now`, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(payload)
                        });

                        if (response.ok) {
                            window.location.href = "/see-you-soon";
                        } else {
                            console.error("Submission failed");
                            alert("Submission failed. Please try again.");
                            submitBtn.textContent = originalText;
                            submitBtn.disabled = false;
                        }
                    } catch (err) {
                        console.error("Error submitting form:", err);
                        alert("An error occurred. Please try again.");
                        submitBtn.textContent = originalText;
                        submitBtn.disabled = false;
                    }
                }
            });
        };

        setupForm();
        document.addEventListener("astro:page-load", setupForm);
    })();
</script>
