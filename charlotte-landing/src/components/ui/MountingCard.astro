---
import ImageWrapper from "../ImageWrapper.astro";
import Button from "../Button.astro";

interface Props {
    title: string;
    description: string;
    image: any;
    href?: string;
    openModal?: string;
}

const {
    title,
    description,
    image,
    href,
    openModal = "booking-modal",
} = Astro.props;
---

<div class="mounting-card" data-open-modal={!href ? openModal : undefined}>
    {href && <a href={href} class="card-link-overlay" />}
    <div class="card-image-container">
        {
            typeof image === "string" ? (
                <img src={image} alt={title} />
            ) : (
                <ImageWrapper media={image} defaultAlt={title} />
            )
        }
    </div>
    <div class="card-content">
        <h3 class="card-title">{title}</h3>
        <p class="card-description">{description}</p>
        <Button
            variant="primary"
            size="small"
            class="card-button"
            href={href}
            data-open-modal={!href ? openModal : undefined}
        >
            {href ? "Start Quiz" : "Book Now"}
        </Button>
    </div>
</div>

<style>
    /* Add-on for link overlay if needed, or just let Button handle it */
    .card-link-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
    }
    .card-content {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .mounting-card {
        background: var(--white);
        border: 1px solid var(--gray-extra-light);
        border-radius: 20px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        min-height: 280px;
        height: 100%;
        width: 100%;
        /* STATIC SHADOWS FOR PREMIUM LOOK - MORE PROMINENT */
        box-shadow:
            0px 4px 10px 0px rgba(0, 0, 0, 0.08),
            0px 12px 24px 0px rgba(0, 0, 0, 0.04);
    }

    /* ENHANCED HOVER SHADOWS - DEEP & EXPRESSIVE */
    .mounting-card:hover {
        border-color: transparent;
        transform: translateY(-10px);
        background-color: var(--white);
        box-shadow:
            0px 8px 15px 0px rgba(0, 0, 0, 0.15),
            0px 25px 25px 0px rgba(0, 0, 0, 0.12),
            0px 50px 35px 0px rgba(0, 0, 0, 0.1),
            0px 85px 45px 0px rgba(0, 0, 0, 0.06),
            0px 130px 50px 0px rgba(0, 0, 0, 0.03);
    }

    .card-image-container {
        width: 100%;
        height: 120px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 24px;
    }

    .card-image-container :global(img) {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        width: 100%;
    }

    .card-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--foreground);
    }

    .card-description {
        font-size: 14px;
        color: var(--gray);
        line-height: 1.5;
        transition:
            opacity 0.3s ease,
            height 0.3s ease;
    }

    :global(.card-button) {
        display: none !important;
    }

    .mounting-card:hover .card-description {
        display: none;
    }

    .mounting-card:hover :global(.card-button) {
        display: flex !important;
    }

    @media (max-width: 600px) {
        .mounting-card {
            padding: 20px 16px;
            min-height: 200px;
        }

        .card-title {
            font-size: 16px;
        }

        .card-description {
            font-size: 12px;
        }
    }
</style>
