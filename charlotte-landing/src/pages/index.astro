---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Reviews from "../components/Reviews.astro";
import FAQ from "../components/FAQ.astro";
import Modal from "../components/Modal.astro";
import Hero from "../components/sections/Hero/index.astro";
import MountingTypes from "../components/sections/MountingTypes/index.astro";
import Advantages from "../components/sections/Advantages/index.astro";
import ExtraServices from "../components/sections/ExtraServices/index.astro";
import CTA from "../components/sections/CTA/index.astro";
import BookingForm from "../components/sections/BookingForm/index.astro";
import VideoReviews from "../components/sections/VideoReviews/index.astro";
import Gallery from "../components/sections/Gallery/index.astro";
import Trust from "../components/sections/Trust/index.astro";
import AboutUs from "../components/sections/AboutUs/index.astro";
import {
    getCityBySlug,
    getCustomerReviews,
    getGalleryPhotos,
    getFAQ,
    getMountingTypes,
    getHero,
    getWorkVideos,
    getGalleryOfWork,
    getTrustData,
    getAboutUs,
    getFinalBlockData,
} from "../lib/strapi";

const citySlug = "chicago";
let cityData = null;
let error = null;
let reviewsMeta = null;
let faqData = null;
let mountingData = null;
let heroData = null;
let videoData = null;
let galleryData = null;
let trustData = null;
let photos = [];
let reviews = [];
let projects = [];
let aboutUsData = null;
let whatWeCareData = null;
let ctaOverride = null;

try {
    const [
        city,
        recData,
        photosData,
        fData,
        mtData,
        hData,
        vData,
        gData,
        tData,
        aData,
    ] = await Promise.all([
        getCityBySlug(citySlug),
        getCustomerReviews(),
        getGalleryPhotos(),
        getFAQ(),
        getMountingTypes(),
        getHero(),
        getWorkVideos(),
        getGalleryOfWork(),
        getTrustData(),
        getAboutUs().catch(() => null), // Fallback if endpoint doesn't exist
    ]);

    cityData = city;
    ctaOverride = city?.cta_override;
    reviewsMeta = getFinalBlockData(city, recData, "customer-reviews");
    mountingData = getFinalBlockData(city, mtData, "tv-mounting-types");
    heroData = getFinalBlockData(city, hData, "hero");
    videoData = getFinalBlockData(city, vData, "see-our-work-in-action");
    galleryData = getFinalBlockData(city, gData, "gallery-of-work");
    trustData = getFinalBlockData(city, tData, "why-customers-choose-us");
    aboutUsData = getFinalBlockData(city, aData, "about-us");
    whatWeCareData =
        getFinalBlockData(city, aData, "what-we-care") || aboutUsData;
    faqData = getFinalBlockData(city, fData, "faq");
    photos = photosData;

    // We still keep 'reviews' array for other purposes if needed, but Reviews.astro now uses metadata
    reviews = Array.isArray(recData)
        ? recData.map((r) => ({ name: r.name, text: r.review_text, rating: 5 }))
        : [];
    projects = Array.isArray(photos)
        ? photos.map((p) => ({ title: p.title, image: p.image }))
        : [];
} catch (e) {
    error = e.message;
    console.error("Error fetching Phase 3 data:", e);
}

const phone = ctaOverride?.phone || cityData?.phone || "(213) 584-4010";
const hours =
    ctaOverride?.workHours || cityData?.hours || "8:00 AM - 10:00 PM DAILY";
const email = ctaOverride?.email || "tvprohandyservices@gmail.com";
const phoneLabel = ctaOverride?.phoneLabel || "";
const cityName = cityData?.city_name || "Chicago";
---

<Layout
    title={`TV Mounting in ${cityName} | TVPro Handy Services`}
    description={cityData?.seo?.metaDescription}
    cityData={cityData}
>
    <Header phone={phone} hours={hours} phoneLabel={phoneLabel} />

    <main>
        <Hero cityName={cityName} data={heroData} />

        {
            error && (
                <div class="error-banner">
                    Note: Partial data loading issues. Some sections may show
                    fallback content.
                </div>
            )
        }

        <MountingTypes data={mountingData} />
        <Advantages />
        <ExtraServices />
        <VideoReviews data={videoData} />

        <Reviews
            title={reviewsMeta?.title}
            subTitle={reviewsMeta?.subTitle}
            cityName={cityName}
        />

        <Gallery galleryOfWorkData={galleryData} galleryPhotos={photos} />

        <Trust data={trustData} />

        <AboutUs cityName={cityName} data={aboutUsData} />

        <FAQ
            title={faqData?.title}
            subTitle={faqData?.subTitle}
            faqs={faqData?.faqs || []}
        />

        <!-- <CTA cityName={cityName} /> -->
    </main>

    <Footer phone={phone} hours={hours} email={email} phoneLabel={phoneLabel} />

    <Modal
        id="booking-modal"
        title="Get a Quick Quote"
        subtitle="Leave your number — we’ll call and give you the exact price"
    >
        <BookingForm cityName={cityName} />
    </Modal>
</Layout>

<style>
    .error-banner {
        background-color: #fef2f2;
        padding: 1rem;
        color: #dc2626;
        text-align: center;
        border-bottom: 1px solid #fee2e2;
        font-size: 0.875rem;
        font-weight: 500;
    }
</style>
